// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: news
// Fields:
//   - title: string (required)
//   - date: string (required)
//   - content: string (required)
//   - category: string (required)
//   - image: string (optional)
//
// Collection: feedback
// Fields:
//   - sufficiency: string (required)
//   - note: string (optional)
//   - timestamp: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        request.auth.token.email == "guncelsinavbilgileri@gmail.com" && 
        request.auth.token.email_verified == true;
    }

    // News Collection
    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Feedback Collection
    match /feedback/{feedbackId} {
      allow create: if true; // Anyone can submit feedback
      allow read, update, delete: if isAdmin(); // Only admin can manage feedback
    }

    // Exam Details Collection
    match /exam_details/{detailId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Fee Details Collection
    match /fee_details/{detailId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // How to Apply Collection
    match /how_to_apply/{detailId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Academic Calendar Collection
    match /academic_calendar/{detailId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // FCM Tokens Collection
    match /fcm_tokens/{tokenId} {
      allow create, update: if true; // Devices need to register their tokens
      allow read, delete: if isAdmin(); // Only admin can manage tokens
    }
  }
}
